# --- Парсинг PDF ----------------------------------------------------
# Облачный API MinerU (https://mineru.net). Не нужен, если установлен
# локальный MinerU (`pip install mineru[core]`) или PyMuPDF.
MINERU_API_KEY=

# --- Провайдеры перевода (нужен хотя бы один, либо локальный сервер) --
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# --- Telegram-бот -----------------------------------------------------
TELEGRAM_BOT_TOKEN=

# --- Django ------------------------------------------------------------
# DJANGO_SECRET_KEY=change-me
# DJANGO_DEBUG=1
# DJANGO_ALLOWED_HOSTS=*
# USE_CELERY=0                       # 1 = celery worker, 0 = фоновые потоки
# CELERY_BROKER_URL=redis://localhost:6379/0
# PDFTRANSL_JOB_QUEUE=pdftransl      # очередь задач (GPU-воркер можно на отдельную)
# PDFTRANSL_AV_SCAN_CMD=clamscan     # антивирус-скан загрузок (пусто = выкл)

# --- Логи ----------------------------------------------------------------
# PDFTRANSL_LOG_LEVEL=DEBUG          # подробные логи ВЕЗДЕ (CLI, бот, сервер):
#                                    # каждый LLM-вызов с размерами/временем,
#                                    # решения парсера/экспорта, ход сегментов
# PDFTRANSL_LOG_FILE=data/pdftransl.log  # дублировать логи в файл (ротация)

# --- Настройки pdftransl (необязательно) ------------------------------
# PDFTRANSL_PROVIDER=ollama
# PDFTRANSL_MODEL=qwen2.5:14b
# PDFTRANSL_BASE_URL=http://localhost:11434/v1
# PDFTRANSL_FALLBACK_PROVIDERS=openrouter   # цепочка на случай сбоя
# PDFTRANSL_PARSER=auto             # mineru_local|mineru_api|nougat|marker|docling|grobid|vlm_ocr|pymupdf
# PDFTRANSL_PARSER_TIMEOUT=1800      # сек до принудительной остановки парсера
# PDFTRANSL_PARSER_FALLBACK=true     # откат на другой парсер, если один упал
# GROBID_URL=http://localhost:8070   # сервер GROBID (бэкенд grobid)
# PDFTRANSL_SOURCE_LANG=en
# PDFTRANSL_TARGET_LANG=ru
# --- сканы (PDF без текстового слоя) -> VLM-OCR ---
# PDFTRANSL_OCR_ON_SCAN=true         # авто-роутинг сканов в OCR
# PDFTRANSL_OCR_DPI=200              # разрешение рендера страниц для OCR
# PDFTRANSL_VISION_MODEL=qwen2.5-vl  # vision-модель для OCR/описания рисунков
# PDFTRANSL_OCR_PROMPT=              # свой промпт OCR (иначе — оптимальный под модель)
# PDFTRANSL_KATEX_DIR=               # свой каталог KaTeX dist (офлайн-формулы)
# Спец-OCR модель (DeepSeek-OCR) для парсинга + отдельная LLM для перевода:
#   vllm serve deepseek-ai/DeepSeek-OCR         # поднять OCR-эндпоинт
#   PDFTRANSL_PARSER=vlm_ocr
#   PDFTRANSL_VISION_PROVIDER=deepseek_ocr      # OCR через vLLM :8000
#   PDFTRANSL_PROVIDER=ollama  PDFTRANSL_MODEL=qwen2.5:14b   # перевод отдельно

# --- защита от нехватки памяти (OOM при MinerU + загрузке модели) ---
# PDFTRANSL_MEMORY_GUARD=true         # логировать память и ждать её освобождения
# PDFTRANSL_MIN_FREE_MEMORY_MB=0      # ждать столько свободной RAM перед загрузкой
#                                     # модели после тяжёлого парсера (0=выкл;
#                                     # поставьте ~ размер модели в МБ, напр. 20000)
# PDFTRANSL_MAX_WORKERS=4            # параллельные переводы сегментов
# PDFTRANSL_RPM=15                   # лимит запросов/мин (бесплатные тарифы)
# PDFTRANSL_ADAPTIVE_THROTTLE=true   # пауза всех потоков при HTTP 429
# PDFTRANSL_EXPORT_FORMATS=html,docx,pdf,latex
# PDFTRANSL_USE_RAG=true
# PDFTRANSL_REVIEW=true
# PDFTRANSL_LEARN=true
# PDFTRANSL_DOC_SUMMARY=true
# PDFTRANSL_AUTO_GLOSSARY=true
# PDFTRANSL_SKIP_REFERENCES=true
# PDFTRANSL_BILINGUAL=false
# PDFTRANSL_PARSE_CACHE=true
# PDFTRANSL_RESUME=true              # возобновлять упавшую задачу с готовых сегментов
# PDFTRANSL_TM_AUTOEXPORT_EVERY=0    # экспорт датасета для дообучения каждые N сегментов TM (0=выкл)
# PDFTRANSL_QUALITY_SCORE=false      # LLM-судья: оценка сегментов 0-100
# PDFTRANSL_FIX_LATEX=true           # LLM-починка битых формул в результате
# PDFTRANSL_RENDER_CHECK=false       # проверка KaTeX-рендера в Chromium
# PDFTRANSL_STRUCTURED_OUTPUTS=false # JSON-mode для ревью/глоссария
# PDFTRANSL_API_TOKEN=               # Bearer-токен на /api/ (пусто = открыт)
# PDFTRANSL_UPLOADS_PER_HOUR=20      # лимит загрузок с одного IP
# PDFTRANSL_DB=data/pdftransl.db
# PDFTRANSL_OUTPUT_DIR=data/output
# PDFTRANSL_DATA_DIR=data            # каталог данных Django/бота
# PDFTRANSL_CHROMIUM=/usr/bin/chromium   # свой бинарь для PDF-экспорта
