# --- Парсинг PDF ----------------------------------------------------
# Облачный API MinerU (https://mineru.net). Не нужен, если установлен
# локальный MinerU (`pip install mineru[core]`) или PyMuPDF.
MINERU_API_KEY=

# --- Провайдеры перевода (нужен хотя бы один, либо локальный сервер) --
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# --- Telegram-бот -----------------------------------------------------
TELEGRAM_BOT_TOKEN=

# --- Django ------------------------------------------------------------
# DJANGO_SECRET_KEY=change-me
# DJANGO_DEBUG=1
# DJANGO_ALLOWED_HOSTS=*
# USE_CELERY=0                       # 1 = celery worker, 0 = фоновые потоки
# CELERY_BROKER_URL=redis://localhost:6379/0

# --- Настройки pdftransl (необязательно) ------------------------------
# PDFTRANSL_PROVIDER=ollama
# PDFTRANSL_MODEL=qwen2.5:14b
# PDFTRANSL_BASE_URL=http://localhost:11434/v1
# PDFTRANSL_FALLBACK_PROVIDERS=openrouter   # цепочка на случай сбоя
# PDFTRANSL_PARSER=auto
# PDFTRANSL_SOURCE_LANG=en
# PDFTRANSL_TARGET_LANG=ru
# PDFTRANSL_MAX_WORKERS=4            # параллельные переводы сегментов
# PDFTRANSL_EXPORT_FORMATS=html,docx,pdf
# PDFTRANSL_USE_RAG=true
# PDFTRANSL_REVIEW=true
# PDFTRANSL_LEARN=true
# PDFTRANSL_DOC_SUMMARY=true
# PDFTRANSL_AUTO_GLOSSARY=true
# PDFTRANSL_SKIP_REFERENCES=true
# PDFTRANSL_BILINGUAL=false
# PDFTRANSL_PARSE_CACHE=true
# PDFTRANSL_DB=data/pdftransl.db
# PDFTRANSL_OUTPUT_DIR=data/output
# PDFTRANSL_DATA_DIR=data            # каталог данных Django/бота
# PDFTRANSL_CHROMIUM=/usr/bin/chromium   # свой бинарь для PDF-экспорта
